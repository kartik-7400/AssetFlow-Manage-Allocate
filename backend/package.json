{
  "name": "assetflow-backend",
  "version": "1.0.0",
  "description": "Backend services for AssetFlow Asset Management & Resource Allocation Platform",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development nodemon --watch src -e ts,js,json --exec node --loader ts-node/esm src/server.ts",
    "build": "rm -rf dist && tsc",
    "seed": "tsc && node dist/seed.js",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@clerk/express": "^1.3.0-alpha.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.4.1",
    "socket.io": "^4.7.5",
    "svix": "^1.24.0",
    "typescript": "^5.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.3",
    "rimraf": "^5.0.7",
    "ts-node-dev": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
